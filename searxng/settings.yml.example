# Copy this file to searxng/settings.yml and replace the secret_key.
# Generate a key with: python3 -c 'import secrets; print(secrets.token_urlsafe(48))'

use_default_settings:
  engines:
    # Keep the default engine list small and reliable for agent use.
    # Notes from real-world testing on container/datacenter IPs:
    # - Bing can return irrelevant results from some IP ranges.
    # - DuckDuckGo and Brave commonly hit CAPTCHA/429 rate limits.
    # - mdn and stackoverflow are not valid engine names in recent SearXNG;
    #   use stackexchange for Stack Overflow-style results.
    keep_only:
      - google
      - qwant
      - yahoo
      - startpage
      - mojeek
      - wikipedia
      - github
      - stackexchange
      - arxiv
      - pypi

server:
  secret_key: "CHANGE_ME_GENERATE_A_RANDOM_SECRET"
  bind_address: "0.0.0.0"
  limiter: false
  public_instance: false
  image_proxy: true
  method: "GET"

search:
  safe_search: 0
  autocomplete: ""
  default_lang: "auto"
  formats:
    - html
    - json
  ban_time_on_fail: 10
  max_ban_time_on_fail: 300

ui:
  static_use_hash: true
  default_theme: simple
  center_alignment: false
  query_in_title: false
  infinite_scroll: true
  results_on_new_tab: true
  theme_args:
    simple_style: auto

outgoing:
  request_timeout: 8.0
  max_request_timeout: 15.0
  pool_connections: 100
  pool_maxsize: 20
  enable_http2: true
