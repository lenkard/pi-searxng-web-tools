# Copy to .env and replace with a strong random value.
# Generate with:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
SEARXNG_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET

# Optional bind overrides.
# SEARXNG_BIND=127.0.0.1
# WEB_API_BIND=127.0.0.1

# Optional free-engine routing and reliability controls used by the wrapper.
# SEARXNG_DEFAULT_ENGINES=google cse,mojeek,yep,bing,mwmbl,wiby
# SEARCH_CACHE_TTL_SECONDS=900
# ENGINE_COOLDOWN_SECONDS=300
# BALANCED_QUALITY_THRESHOLD=0.58

# Optional FastAPI wrapper shared key.
# WEB_API_KEY=change-me-long-random-token

# Engine-health probe tuning (all optional; sensible defaults below).
# The API monitors each engine and auto-excludes chronically broken ones from
# default search. See /engines/health for live status.
# WEBFETCH_DATA_DIR=/data
# PROBE_QUERY=open source software
# PROBE_INTERVAL_GENERAL=900      # seconds between general-engine probes
# PROBE_INTERVAL_CSE=7200         # seconds between public-CSE probes (quota-friendly)
# PROBE_TICK_SECONDS=60           # how often the loop re-evaluates due engines
# PROBE_STAGGER_SECONDS=3         # pause between individual probes in a sweep
# PROBE_STARTUP_DELAY=30          # delay before the first sweep
# ENGINE_BROKEN_THRESHOLD=3       # consecutive failures before an engine is "broken"
# LOG_LEVEL=INFO

# SearXNG settings.yml path. The API reads this at startup to derive its engine
# allowlist (single source of truth). Compose mounts it read-only into the API.
# SEARXNG_SETTINGS_PATH=/etc/searxng/settings.yml

# Optional proxynet override values used by docker-compose.proxynet.yml.
# PROXYNET_NAME=proxynet
# SEARXNG_PROXYNET_IP=172.19.0.10
# WEBFETCH_PROXYNET_IP=172.19.0.11
