# Copy this file to searxng/settings.yml.
# The SearXNG secret is provided by the SEARXNG_SECRET environment variable.
# Generate one with: python3 -c 'import secrets; print(secrets.token_urlsafe(48))'

use_default_settings:
  engines:
    # Keep the default engine list small and reliable for agent use.
    # Observed from a new OCI datacenter IP on 2026-07-10:
    # - Bing, Mojeek, Yep, Wiby, and Mwmbl returned results. Mwmbl and
    #   Wiby have much smaller independent indexes.
    # - Brave returned 429, DuckDuckGo/Startpage returned CAPTCHA,
    #   Qwant denied access, and Yahoo had protocol errors.
    # - Scraping-based engines can change behavior at any time. Use an
    #   official search API as the long-term primary and SearXNG as fallback.
    keep_only:
      - bing
      - mojeek
      - yep
      - mwmbl
      - wiby
      - wikipedia
      - github
      - arxiv
      - pypi

server:
  # server.secret_key is provided by the SEARXNG_SECRET environment variable.
  # Keep the actual secret in .env, not in this file.
  bind_address: "0.0.0.0"
  limiter: false
  public_instance: false
  image_proxy: true
  method: "GET"

search:
  safe_search: 0
  autocomplete: ""
  default_lang: "auto"
  formats:
    - html
    - json
  ban_time_on_fail: 10
  max_ban_time_on_fail: 300

ui:
  static_use_hash: true
  default_theme: simple
  center_alignment: false
  query_in_title: false
  infinite_scroll: true
  results_on_new_tab: true
  theme_args:
    simple_style: auto

outgoing:
  request_timeout: 8.0
  max_request_timeout: 15.0
  pool_connections: 100
  pool_maxsize: 20
  enable_http2: true
