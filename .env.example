# Copy to .env and replace with a strong random value.
# Generate with:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
SEARXNG_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET

# Optional bind overrides.
# SEARXNG_BIND=127.0.0.1
# WEB_API_BIND=127.0.0.1

# Optional provider secrets. Keep the key files ignored and outside settings.yml.
# Without these overrides Compose mounts tracked empty placeholders; set the free
# fallback chain below if you do not use Z.AI or Serper.
# ZAI_API_KEY_FILE=./searxng/secrets/zai_api_key
# SERPER_API_KEY_FILE=./searxng/secrets/serper_api_key

# Optional provider routing and reliability controls used by the wrapper.
# The hosted providers are primary when their key files are configured.
# SEARXNG_DEFAULT_ENGINES=serper,zai,bing,yep,mwmbl,wiby
# No hosted-provider keys: SEARXNG_DEFAULT_ENGINES=bing,yep,mwmbl,wiby
# SEARCH_CACHE_TTL_SECONDS=900
# ENGINE_COOLDOWN_SECONDS=300
# BALANCED_QUALITY_THRESHOLD=0.58

# Optional FastAPI wrapper shared key.
# WEB_API_KEY=change-me-long-random-token

# Keep false unless this trusted deployment intentionally fetches internal URLs.
# WEB_FETCH_ALLOW_PRIVATE=false

# Runtime-driven engine health (all optional; sensible defaults below).
# Real searches update health. A non-rate-limit failure gets one delayed
# confirmation; healthy and unused engines are never probed.
# WEBFETCH_DATA_DIR=/data
# PROBE_QUERY=open source software       # query used only to confirm a failure
# CONFIRM_FAILURE_DELAY_SECONDS=5
# HEALTH_STALE_SECONDS=86400
# CSE_MIN_INTERVAL_SECONDS=10     # minimum spacing between all Google-CSE requests
# LOG_LEVEL=INFO

# SearXNG settings.yml path. The API reads this at startup to derive its engine
# allowlist (single source of truth). Compose mounts it read-only into the API.
# SEARXNG_SETTINGS_PATH=/etc/searxng/settings.yml

# Optional proxynet override values used by docker-compose.proxynet.yml.
# PROXYNET_NAME=proxynet
# SEARXNG_PROXYNET_IP=172.19.0.10
# WEBFETCH_PROXYNET_IP=172.19.0.11
